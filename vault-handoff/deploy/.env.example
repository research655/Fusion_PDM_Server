# Copy this to deploy/.env and fill in. Do NOT commit deploy/.env.

# Strong password for the Postgres superuser (used by the API too):
POSTGRES_PASSWORD=change-me-to-something-strong

# --- UniFi NAS blob storage (mounted over NFS) ---
# IP address of the UniFi NAS on the LAN:
UNAS_IP=192.168.1.50
# The REAL NFS export path for your Vault share. It is NOT the path shown in the
# UniFi dashboard. Find it from the Docker host with:
#     showmount -e <UNAS_IP>
# It looks like: /volume1/.srv/.unifi-drive/<Shared Drive Name>/.data
UNAS_EXPORT_PATH=/volume1/.srv/.unifi-drive/vault-data/.data
