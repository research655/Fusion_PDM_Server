# Copy to your environment / user-secrets. Never commit real values.
# Local dev runs WITHOUT these (stub integrations are the default).

# PostgreSQL
ConnectionStrings__Vault=Host=localhost;Database=vault;Username=postgres;Password=postgres

# Google OAuth (Phase 5) — restrict to @sparkrobotic.com
Auth__Google__ClientId=
Auth__Google__ClientSecret=

# Asana (Phase 5)
Asana__Token=
Asana__WorkspaceId=
Asana__ApprovalProjectId=

# Storage: Local (default) or S3
Storage__Provider=Local
Storage__Local__RootPath=C:\VaultData
# Storage__S3__Bucket=
# Storage__S3__Region=
